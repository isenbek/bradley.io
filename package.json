{
  "name": "bradley-io",
  "version": "1.0.152",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"NEXT,WARGAMES\" -c \"cyan,green\" \"npm run dev:next\" \"npm run dev:wargames\"",
    "dev:next": "node scripts/generate-build-info.js && next dev -p 32221",
    "dev:wargames": "nodemon wargames-server.js",
    "build": "node scripts/generate-build-info.js && next build",
    "build:info": "node scripts/generate-build-info.js",
    "start": "next start",
    "lint": "eslint .",
    "audit": "playwright test tests/site-audit.spec.ts tests/visual.spec.ts tests/no-external.spec.ts",
    "audit:all": "AUDIT_SCOPE=all playwright test tests/site-audit.spec.ts",
    "audit:no-external": "playwright test tests/no-external.spec.ts",
    "audit:desktop": "playwright test --project=desktop",
    "audit:tablet": "playwright test --project=tablet",
    "audit:mobile": "playwright test --project=mobile",
    "audit:visual": "playwright test tests/visual.spec.ts",
    "audit:visual:update": "playwright test tests/visual.spec.ts --update-snapshots",
    "audit:perf": "playwright test tests/perf-budget.spec.ts --project=desktop",
    "audit:perf:prod": "PLAYWRIGHT_BASE_URL=https://bradley.io playwright test tests/perf-budget.spec.ts --project=desktop",
    "audit:report": "playwright show-report"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.1.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/d3": "^7.4.3",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.563.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.1.6",
    "ollama": "^0.5.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.2.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lighthouse": "^13.4.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.54.0"
  }
}
